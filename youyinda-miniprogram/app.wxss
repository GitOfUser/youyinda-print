/**
 * 优印达小程序 - 全局样式
 * 1:1还原UI设计稿的色值、字体、间距规范
 */

/* ==================== CSS变量定义 ==================== */
page {
  /* 品牌主色 */
  --primary: #FF7D00;
  --primary-light: #FFF3E8;
  --primary-dark: #E06E00;
  --primary-gradient: linear-gradient(135deg, #FF7D00 0%, #FF9A3C 100%);

  /* 语义色 */
  --success: #00B42A;
  --success-light: #E8F7EC;
  --danger: #F53F3F;
  --danger-light: #FEE8E8;
  --info: #165DFF;
  --info-light: #E8EDFF;
  --warning: #FF7D00;

  /* 品牌背景 */
  --bg-cream: #F9F6F0;

  /* 中性色 */
  --text-title: #1D2129;
  --text-body: #4E5969;
  --text-secondary: #86909C;
  --border: #E5E6EB;
  --bg-gray: #F2F3F5;
  --white: #FFFFFF;

  /* 圆角 */
  --radius-btn: 8px;
  --radius-card: 12px;
  --radius-input: 6px;
  --radius-icon: 4px;

  /* 阴影 */
  --shadow-sm: 0 1px 4px rgba(0,0,0,0.08);
  --shadow-md: 0 4px 16px rgba(0,0,0,0.10);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.12);

  /* 字体尺寸 */
  --fs-xl: 20px;
  --fs-lg: 18px;
  --fs-md: 16px;
  --fs-base: 14px;
  --fs-sm: 12px;

  /* 页面背景 */
  background-color: var(--bg-cream);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: var(--text-title);
}

/* ==================== 通用布局类 ==================== */
.container {
  min-height: 100vh;
  background-color: var(--bg-cream);
  padding-bottom: 30px;
}

.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

/* ==================== 通用组件类 ==================== */
/* 主按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: var(--primary-gradient);
  color: white;
  font-size: var(--fs-md);
  font-weight: 600;
  border-radius: var(--radius-btn);
  border: none;
  box-shadow: 0 4px 24rpx rgba(255,125,0,0.35);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.95;
}

.btn-primary[disabled] {
  background: #C9CDD4;
  box-shadow: none;
}

/* 次要按钮 */
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: white;
  color: var(--text-body);
  font-size: var(--fs-base);
  font-weight: 500;
  border-radius: var(--radius-btn);
  border: 1.5px solid var(--border);
}

.btn-secondary:active {
  background: var(--bg-gray);
}

/* 文字按钮 */
.btn-text {
  display: inline-flex;
  align-items: center;
  color: var(--primary);
  font-size: var(--fs-base);
  font-weight: 500;
  padding: 8rpx 16rpx;
}

/* 卡片 */
.card {
  background: white;
  border-radius: var(--radius-card);
  margin: 0 24rpx 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.card-flat {
  background: white;
  border-radius: var(--radius-card);
  margin: 0 24rpx 24rpx;
  overflow: hidden;
}

/* 输入框 */
.input {
  width: 100%;
  height: 76rpx;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-input);
  padding: 0 20rpx;
  font-size: var(--fs-base);
  color: var(--text-title);
  background: var(--bg-gray);
  box-sizing: border-box;
}

.input:focus {
  border-color: var(--primary);
  background: white;
}

.input::placeholder {
  color: var(--text-secondary);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary);
}

.tag-success {
  background: var(--success-light);
  color: var(--success);
}

.tag-danger {
  background: var(--danger-light);
  color: var(--danger);
}

.tag-info {
  background: var(--info-light);
  color: var(--info);
}

/* 分隔线 */
.divider {
  height: 16rpx;
  background: var(--bg-gray);
}

.line {
  height: 1px;
  background: var(--border);
  transform: scaleY(0.5);
  transform-origin: 0 0;
}

/* ==================== 文字样式类 ==================== */
.text-title {
  font-size: var(--fs-xl);
  font-weight: 700;
  color: var(--text-title);
}

.text-lg {
  font-size: var(--fs-lg);
  font-weight: 600;
  color: var(--text-title);
}

.text-md {
  font-size: var(--fs-md);
  font-weight: 600;
  color: var(--text-title);
}

.text-base {
  font-size: var(--fs-base);
  color: var(--text-body);
}

.text-sm {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
}

.text-primary {
  color: var(--primary);
}

.text-success {
  color: var(--success);
}

.text-danger {
  color: var(--danger);
}

.text-secondary {
  color: var(--text-secondary);
}

/* ==================== 间距类 ==================== */
.m-12 { margin: 24rpx; }
.m-16 { margin: 32rpx; }
.mt-8 { margin-top: 16rpx; }
.mt-12 { margin-top: 24rpx; }
.mt-16 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 16rpx; }
.mb-12 { margin-bottom: 24rpx; }
.mb-16 { margin-bottom: 32rpx; }
.ml-8 { margin-left: 16rpx; }
.mr-8 { margin-right: 16rpx; }

.p-12 { padding: 24rpx; }
.p-16 { padding: 32rpx; }
.pt-8 { padding-top: 16rpx; }
.pt-12 { padding-top: 24rpx; }
.pb-8 { padding-bottom: 16rpx; }
.pb-12 { padding-bottom: 24rpx; }
.pl-12 { padding-left: 24rpx; }
.pr-12 { padding-right: 24rpx; }

/* ==================== 底部固定栏 ==================== */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  border-top: 1px solid var(--border);
  box-shadow: 0 -2px 16rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.bottom-bar-placeholder {
  height: 140rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: var(--fs-base);
  color: var(--text-secondary);
  text-align: center;
}

/* ==================== 加载状态 ==================== */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

/* ==================== 安全区域适配 ==================== */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 隐藏滚动条 ==================== */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  background: transparent;
}
