.container {
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 160rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.company-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.company-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid transparent;
}

.company-item.active {
  border-color: #1890ff;
  background: #e6f7ff;
}

.company-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.company-logo {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.company-info {
  flex: 1;
}

.company-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.company-desc {
  font-size: 22rpx;
  color: #999;
}

.company-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.company-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.radio {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
}

.radio.checked {
  border-color: #1890ff;
  background: #1890ff;
  position: relative;
}

.radio.checked::after {
  content: '';
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  background: #fff;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-info {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.btn-next {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #ff7a45 0%, #fa541c 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 48rpx;
  font-weight: 500;
}

.btn-next.disabled {
  background: #d9d9d9;
  color: #999;
}
