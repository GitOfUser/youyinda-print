.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.help-list {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.help-item {
  border-bottom: 1rpx solid #f0f0f0;
}

.help-item:last-child {
  border-bottom: none;
}

.help-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
}

.question-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.question-arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s;
}

.question-arrow.expanded {
  transform: rotate(180deg);
}

.help-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s;
  padding: 0 30rpx;
}

.help-answer.show {
  max-height: 500rpx;
  padding: 0 30rpx 30rpx;
}

.answer-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.contact-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.contact-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.contact-text {
  font-size: 28rpx;
  color: #333;
}
