<view class="container">
  <view class="form-section">
    <view class="form-item">
      <view class="form-label">收货人</view>
      <input class="form-input" placeholder="请输入收货人姓名" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>
    <view class="form-item">
      <view class="form-label">手机号码</view>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号码" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
    </view>
    <view class="form-item" bindtap="selectRegion">
      <view class="form-label">所在地区</view>
      <view class="form-value {{!form.province ? 'placeholder' : ''}}">{{form.province ? form.province + form.city + form.district : '请选择省/市/区'}}</view>
    </view>
    <view class="form-item">
      <view class="form-label">详细地址</view>
      <textarea class="form-textarea" placeholder="请输入详细地址，如街道、门牌号等" value="{{form.detail}}" bindinput="onInput" data-field="detail" maxlength="100" />
    </view>
    <view class="form-item switch-item">
      <view class="form-label">设为默认地址</view>
      <switch checked="{{form.isDefault}}" bindchange="onSwitchChange" color="#1890ff" />
    </view>
  </view>

  <view class="save-btn" bindtap="saveAddress">保存</view>
</view>
