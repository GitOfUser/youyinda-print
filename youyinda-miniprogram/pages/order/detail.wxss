.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.status-card {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.status-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.info-card,
.address-card,
.content-card,
.price-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #333;
}

.address-label {
  font-size: 24rpx;
  color: #1890ff;
  background: #e6f7ff;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-bottom: 20rpx;
}

.address-info .address-top {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 26rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.content-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.content-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.row-label {
  font-size: 26rpx;
  color: #666;
}

.row-value {
  font-size: 26rpx;
  color: #333;
}

.price-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 26rpx;
  color: #333;
}

.price-value.discount {
  color: #ff4d4f;
}

.price-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

.price-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.total-value {
  font-size: 40rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 20rpx;
}

.bottom-bar view {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-pay,
.btn-track {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
}
