/* 空状态组件样式 */
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 28rpx;
  color: #4E5969;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #86909C;
  text-align: center;
  line-height: 1.5;
}

.empty-btn {
  margin-top: 40rpx;
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #FF7D00 0%, #FF9A3C 100%);
  color: white;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 8rpx;
  box-shadow: 0 4px 24rpx rgba(255,125,0,0.35);
}

.empty-btn:active {
  transform: scale(0.98);
  opacity: 0.95;
}
